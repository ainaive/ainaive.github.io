---
import { type Locale, ui } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
---

<nav class="lang-toggle" aria-label={t.langToggle.label}>
  <a
    href="/"
    lang="en"
    hreflang="en"
    aria-current={locale === "en" ? "page" : undefined}>EN</a
  >
  <span aria-hidden="true">·</span>
  <a
    href="/zh/"
    lang="zh-Hans"
    hreflang="zh-Hans"
    aria-current={locale === "zh" ? "page" : undefined}>中文</a
  >
</nav>

<style>
  .lang-toggle {
    display: flex;
    gap: 0.6em;
    align-items: baseline;
    font-size: var(--step--1);
    color: var(--ink-muted);
  }

  a {
    text-decoration: none;
    color: inherit;
    padding: 0.2em 0.1em;
  }

  a:hover {
    color: var(--seal);
  }

  a[aria-current="page"] {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--seal);
    text-decoration-thickness: 2px;
    text-underline-offset: 0.3em;
  }
</style>
