---
import { getCollection } from "astro:content";

import { type Locale, ui } from "../i18n/ui";
import AppRow from "./AppRow.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];

const apps = (await getCollection("apps"))
  .map((entry) => entry.data)
  .sort((a, b) => a.order - b.order);
---

<section class="shelf" aria-labelledby="shelf-heading">
  <h2 id="shelf-heading">{t.shelf.heading}</h2>
  <p class="lede">{t.shelf.lede}</p>
  {/* role kept: Safari/VoiceOver drop list semantics under list-style:none */}
  <ol role="list">
    {
      apps.map((app, index) => (
        <AppRow app={app} index={index} locale={locale} />
      ))
    }
  </ol>
</section>

<style>
  .shelf {
    padding-block-start: var(--space-xl);
  }

  h2 {
    font-size: var(--step-1);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .lede {
    margin-block: 0.6em var(--space-l);
    max-inline-size: 34em;
    color: var(--ink-muted);
  }

  ol {
    list-style: none;
    padding: 0;
    border-block-end: 1px solid var(--rule);
  }
</style>
