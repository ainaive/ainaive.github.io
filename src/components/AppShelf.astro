---
import { getCollection } from "astro:content";

import { type Locale, ui } from "../i18n/ui";
import AppTile from "./AppTile.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];

const apps = (await getCollection("apps"))
  .map((entry) => entry.data)
  .sort((a, b) => a.order - b.order);
---

<section class="shelf" aria-labelledby="shelf-heading">
  <h2 id="shelf-heading">{t.shelf.heading}</h2>
  <p class="lede">{t.shelf.lede}</p>
  {/* role kept: Safari/VoiceOver drop list semantics under list-style:none */}
  <ol role="list">
    {
      apps.map((app, index) => (
        <AppTile app={app} index={index} locale={locale} />
      ))
    }
    <li class="colophon"><p>{t.shelf.colophon}</p></li>
  </ol>
</section>

<style>
  .shelf {
    padding-block-start: var(--space-xl);
  }

  h2 {
    font-size: var(--step-1);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .lede {
    margin-block: 0.6em var(--space-l);
    max-inline-size: 34em;
    color: var(--ink-muted);
  }

  /* the stamp sheet: cells share hairlines, no gaps. The container draws
     the start edges, every cell its end edges — so the sheet stays correct
     at any cell count, including a ragged last row. */
  ol {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    list-style: none;
    padding: 0;
    border-block-start: 1px solid var(--rule);
    border-inline-start: 1px solid var(--rule);
  }

  ol > :global(li) {
    border-inline-end: 1px solid var(--rule);
    border-block-end: 1px solid var(--rule);
  }

  .colophon {
    display: flex;
    align-items: flex-end;
    padding: var(--space-m);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-muted);
  }

  @media (max-width: 64rem) {
    ol {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 40rem) {
    ol {
      grid-template-columns: 1fr;
    }
  }
</style>
