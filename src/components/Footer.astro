---
import { type Locale, site, ui } from "../i18n/ui";
import Seal from "./Seal.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
---

<footer>
  <div class="shell inner">
    <p class="line">
      <Seal size={22} label={t.footer.sealAria} />
      <span>{t.footer.line}</span>
    </p>
    <nav aria-label={t.footer.links.github + " · " + t.footer.links.blog}>
      <a href={site.author.github} rel="noopener">
        {t.footer.links.github}<span aria-hidden="true"> ↗</span>
      </a>
      <a href={site.author.blog} rel="noopener">
        {t.footer.links.blog}<span aria-hidden="true"> ↗</span>
      </a>
    </nav>
  </div>
</footer>

<style>
  footer {
    border-block-start: 1px solid var(--rule);
  }

  .inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: wrap;
    padding-block: var(--space-l);
    font-size: var(--step--1);
    color: var(--ink-muted);
  }

  .line {
    display: flex;
    align-items: center;
    gap: 0.75em;
  }

  nav {
    display: flex;
    gap: 1.5em;
    font-family: var(--font-mono);
  }
</style>
