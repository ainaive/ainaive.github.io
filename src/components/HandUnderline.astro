---
/**
 * The one handmade gesture per screen: a slightly irregular ink stroke.
 * Decorative only.
 */
---

<svg
  class="hand-underline"
  viewBox="0 0 220 10"
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <path
    d="M3 6.8 C 38 3.6, 74 6.6, 108 5.2 C 142 3.9, 176 6.4, 217 4.6"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"></path>
</svg>

<style>
  .hand-underline {
    display: block;
    inline-size: min(14em, 60vw);
    block-size: 0.5em;
    color: var(--seal);
  }
</style>
