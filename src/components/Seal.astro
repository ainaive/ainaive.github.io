---
/**
 * The AI Naive seal (印章): a slightly irregular hand-cut square in seal red
 * with lowercase "ai" knocked out in paper. Decorative by default — pass a
 * label only where it stands alone.
 */
interface Props {
  size?: number;
  label?: string;
}

const { size = 36, label } = Astro.props;
---

<svg
  class="seal"
  width={size}
  height={size}
  viewBox="0 0 64 64"
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : "true"}
>
  <path
    d="M7 9.5 C 21 6.5, 43 6, 57 8.5 C 59.5 22, 59 41, 57 55.5 C 43 58.5, 20 58, 8.5 56 C 5.5 42, 5.5 23, 7 9.5 Z"
    fill="currentColor"></path>
  <g
    stroke="var(--paper, #f7f3eb)"
    stroke-width="5.5"
    stroke-linecap="round"
    fill="none"
  >
    <circle cx="23.5" cy="37" r="7.5"></circle>
    <path d="M31 29.5 V 44.5"></path>
    <path d="M44 29.5 V 44.5"></path>
  </g>
  <circle cx="44" cy="19.5" r="3.4" fill="var(--paper, #f7f3eb)"></circle>
</svg>

<style>
  .seal {
    display: block;
    color: var(--seal);
  }
</style>
