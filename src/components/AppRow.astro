---
import { type Locale, ui } from "../i18n/ui";
import type { App } from "../lib/schema";

interface Props {
  app: App;
  index: number;
  locale: Locale;
}

const { app, index, locale } = Astro.props;
const t = ui[locale];
const numeral = String(index + 1).padStart(2, "0");
const accent = `--accent: light-dark(${app.accent.light}, ${app.accent.dark})`;

const links = [
  app.links.live && { href: app.links.live, label: t.appLinks.live },
  app.links.github && { href: app.links.github, label: t.appLinks.github },
].filter((l): l is { href: string; label: string } => Boolean(l));
---

<li class="app-row" style={accent}>
  <span class="index" aria-hidden="true">{numeral}</span>
  <div class="body">
    <h3 class="name">
      <span lang="en">{app.name}</span>
      <span class="status">{t.status[app.status]}</span>
    </h3>
    <p class="tagline">{app.tagline[locale]}</p>
    <p class="desc">{app.description[locale]}</p>
    <ul class="meta">
      {app.meta[locale].map((fact) => <li>{fact}</li>)}
    </ul>
  </div>
  {
    links.length > 0 && (
      <nav class="links" aria-label={app.name}>
        {links.map((link) => (
          <a href={link.href} rel="noopener">
            {link.label}
            <span aria-hidden="true"> ↗</span>
          </a>
        ))}
      </nav>
    )
  }
</li>

<style>
  .app-row {
    position: relative;
    display: grid;
    grid-template-columns: 6rem 1fr auto;
    gap: var(--space-m);
    padding-block: var(--space-l);
    border-block-start: 1px solid var(--rule);
  }

  .app-row::before {
    content: "";
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    inline-size: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
  }

  .app-row:hover::before {
    transform: scaleY(1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .app-row::before {
      transition: transform 240ms ease;
    }
  }

  .index {
    font-size: var(--step-3);
    font-weight: 500;
    line-height: 1;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  .name {
    display: flex;
    align-items: baseline;
    gap: 0.75em;
    flex-wrap: wrap;
    font-size: var(--step-2);
    font-weight: 500;
    line-height: 1.2;
  }

  .status {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 400;
    color: var(--accent);
    border: 1px solid color-mix(in oklab, var(--accent) 55%, var(--paper));
    padding: 0.05em 0.55em;
    white-space: nowrap;
  }

  .tagline {
    margin-block-start: 0.5em;
    font-weight: 500;
  }

  .desc {
    margin-block-start: 0.5em;
    max-inline-size: 34em;
    color: var(--ink-muted);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em 0;
    list-style: none;
    margin-block-start: 0.9em;
    padding: 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-muted);
  }

  .meta li:not(:last-child)::after {
    content: "·";
    margin-inline: 0.7em;
    opacity: 0.6;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    align-items: flex-end;
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  .links a {
    text-decoration-color: color-mix(in oklab, var(--accent) 45%, transparent);
  }

  .links a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  @media (max-width: 40rem) {
    .app-row {
      grid-template-columns: 1fr;
      gap: var(--space-s);
    }

    .index {
      font-size: var(--step-1);
    }

    .links {
      flex-direction: row;
      align-items: baseline;
      gap: 1.5em;
    }
  }
</style>
