---
import Seal from "../components/Seal.astro";
import { ui } from "../i18n/ui";
import Base from "../layouts/Base.astro";

const en = ui.en.notFound;
const zh = ui.zh.notFound;
---

<Base locale="en" title={en.title} noSeo>
  <main id="main" class="shell">
    <p class="mark"><Seal size={44} /></p>
    <h1>404</h1>
    <section>
      <p>{en.message}</p>
      <a href="/">{en.backHome}</a>
    </section>
    <section lang="zh-Hans">
      <p>{zh.message}</p>
      <a href="/zh/" hreflang="zh-Hans">{zh.backHome}</a>
    </section>
  </main>
</Base>

<style>
  main {
    min-block-size: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-m);
    padding-block: var(--space-xl);
  }

  .mark {
    margin: 0;
  }

  h1 {
    font-size: var(--step-4);
    font-weight: 500;
    line-height: 1;
    color: var(--seal);
  }

  section {
    max-inline-size: 34em;
  }

  section + section {
    border-block-start: 1px solid var(--rule);
    padding-block-start: var(--space-m);
  }

  section p {
    margin-block-end: 0.5em;
  }
</style>
